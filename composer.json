{
    "name": "lerouse/laravel-repository",
    "description": "Repository implementation for Laravel.",
    "keywords": ["laravel", "eloquent", "database", "repository"],
    "type": "package",
    "license": "MIT",
    "authors": [
        {
            "name": "Christian Innerbichler"
        }
    ],
    "require": {
        "php": "^8.1|^8.2|^8.3|^8.4",
        "ext-json": "*",
        "illuminate/contracts": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/events": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/database": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "laravel/legacy-factories": "^1.2"
    },
    "require-dev": {
        "mockery/mockery": "~1.0",
        "orchestra/testbench": "^8.0||^9.0||^10.0||^11.0",
        "phpunit/phpunit": "^10.0||^11.0||^12.0"
    },
    "autoload": {
        "psr-4": {
            "Lerouse\\LaravelRepository\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lerouse\\LaravelRepository\\Tests\\": "tests"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "extra": {
        "laravel": {
            "providers": [
                "Lerouse\\LaravelRepository\\LaravelRepositoryServiceProvider"
            ]
        }
    }
}
